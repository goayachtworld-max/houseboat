# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by default)
DATABASE_URL=postgresql://user:password@localhost:5432/houseboat

# ── API Server ────────────────────────────────────────────────────────────────
# Port the API server listens on
PORT=8080

# Session secret (change to a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Port the frontend dev server listens on
PORT=5173

# Base path if serving from a subdirectory (leave as / for root)
BASE_PATH=/

# ── Image Storage (for self-hosted / cPanel deployment) ───────────────────────
# Absolute path on your server where uploaded images are saved
UPLOAD_DIR=/home/youruser/public_html/uploads

# Public URL prefix for uploaded images
UPLOAD_BASE_URL=https://yourdomain.com/uploads
