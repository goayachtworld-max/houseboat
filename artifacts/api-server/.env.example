# ============================================================
# Backend environment variables  (artifacts/api-server)
# ============================================================
# Copy this file to .env on your VPS, then fill in real values.
# Never commit .env to git.
# ============================================================

# Node environment
NODE_ENV=production

# Port the Express server listens on
PORT=3001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://dbuser:dbpassword@localhost:5432/houseboat

# CORS — comma-separated list of allowed frontend origins.
# Must match exactly what the browser sends as the Origin header.
# Example (single domain):
#   CORS_ORIGIN=https://yourdomain.com
# Example (www + apex):
#   CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
