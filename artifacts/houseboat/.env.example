# ============================================================
# Frontend environment variables  (artifacts/houseboat)
# ============================================================
# Copy this file to .env.production before running:
#   pnpm --filter @workspace/houseboat build
#
# .env.production is gitignored — never commit real values.
# ============================================================

# URL of your VPS backend — no trailing slash.
# Example: https://api.yourdomain.com
# Leave empty to use same-origin (only valid for local dev).
VITE_API_URL=https://api.yourdomain.com

# Vite base path — leave as "/" unless you deploy to a subdirectory.
# Example: if site is at yourdomain.com/houseboat/ set BASE_PATH=/houseboat/
BASE_PATH=/
